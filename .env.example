# Get your free API key at https://app.roboflow.com/settings/api
ROBOFLOW_API_KEY=your_roboflow_api_key_here

# Roboflow Universe model (YOLOv8s, 1314 images)
# https://universe.roboflow.com/yolo-v8-solrb/plant-disease-ep6jy/model/2
MODEL_ID=plant-disease-ep6jy/2

# serverless = Roboflow hosted API (default, easiest)
# local      = your own Roboflow Inference Server (Docker on port 9001)
INFERENCE_MODE=serverless
# Only used when INFERENCE_MODE=local (self-hosted Roboflow Inference Server)
INFERENCE_API_URL=http://localhost:9001

CONFIDENCE_THRESHOLD=0.4
HOST=0.0.0.0
PORT=8001
